
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskManager</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Plugins -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.10.16/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/1.1.3/sweetalert.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <link href="~/css/layout.css" rel="stylesheet" />
</head>

<body>

  
    <nav class="tm-navbar navbar navbar-expand-lg">
        <div class="container-fluid">

            <!-- Brand -->
            <a class="tm-brand" asp-controller="Home" asp-action="Index">
                <div class="brand-icon"><i class="fa fa-check"></i></div>
                TaskManager
            </a>

            <button class="navbar-toggler ms-auto" type="button"
                    data-bs-toggle="collapse" data-bs-target="#tmNav">
                <i class="fa fa-bars" style="color:#8b5cf6;font-size:.9rem;"></i>
            </button>

            <div class="collapse navbar-collapse ms-4" id="tmNav">

                <!-- LEFT LINKS -->
                <ul class="navbar-nav me-auto align-items-lg-center gap-1">

                    <li class="nav-item">
                        <a class="tm-nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fa fa-house"></i> Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="tm-nav-link" asp-controller="Home" asp-action="Privacy">
                            <i class="fa fa-shield-halved"></i> Privacy
                        </a>
                    </li>

                    @if (Context.Session.GetString("Role") == "Admin")
                    {
                        <div class="nav-divider d-none d-lg-block"></div>

                        <li class="nav-item">
                            <a class="tm-nav-link active-link" asp-controller="Admin" asp-action="Index">
                                <i class="fa fa-gauge"></i> Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="tm-nav-link" asp-controller="Admin" asp-action="Users">
                                <i class="fa fa-users"></i> Users
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="tm-nav-link" asp-controller="Admin" asp-action="Tasks">
                                <i class="fa fa-list-check"></i> Tasks
                            </a>
                        </li>
                    }

                    @if (Context.Session.GetString("Role") == "Employee")
                    {
                        <div class="nav-divider d-none d-lg-block"></div>

                        <li class="nav-item">
                            <a class="tm-nav-link active-link" asp-controller="Employee" asp-action="MyTasks">
                                <i class="fa fa-list-check"></i> My Tasks
                            </a>
                        </li>
                    }

                </ul>

                <!-- RIGHT LINKS -->
                <ul class="navbar-nav align-items-lg-center gap-2 mt-2 mt-lg-0">

                    @if (Context.Session.GetString("JWToken") == null)
                    {
                        <li class="nav-item">
                            <a class="tm-btn-ghost outline" asp-controller="Account" asp-action="Login">
                                <i class="fa fa-right-to-bracket"></i> Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="tm-btn-ghost filled" asp-controller="Account" asp-action="Register">
                                <i class="fa fa-user-plus"></i> Register
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <span class="user-chip">
                                <i class="fa fa-circle-user"></i>
                                @Context.Session.GetString("Name")
                                <span class="role-badge">@Context.Session.GetString("Role")</span>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="tm-btn-ghost danger" asp-controller="Account" asp-action="Logout">
                                <i class="fa fa-right-from-bracket"></i> Logout
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

   
    <div class="tm-main">
        <div class="container">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

  
    <footer class="tm-footer">
        <div class="container footer-inner">
            <div class="row g-4">

                <!-- Brand col -->
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand">
                        <div class="brand-icon"><i class="fa fa-check"></i></div>
                        TaskManager
                    </div>
                    <p class="footer-tagline">A simple, powerful task management system for teams. Assign, track, and complete tasks with ease.</p>
                </div>

                <!-- Quick links -->
                <div class="col-lg-2 col-md-3 col-6">
                    <p class="footer-heading">Navigation</p>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index"><i class="fa fa-house"></i>Home</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy"><i class="fa fa-shield-halved"></i>Privacy</a></li>
                        <li><a asp-controller="Account" asp-action="Login"><i class="fa fa-right-to-bracket"></i>Login</a></li>
                        <li><a asp-controller="Account" asp-action="Register"><i class="fa fa-user-plus"></i>Register</a></li>
                    </ul>
                </div>

                <!-- Features -->
                <div class="col-lg-2 col-md-3 col-6">
                    <p class="footer-heading">Features</p>
                    <ul class="footer-links">
                        <li><a href="#"><i class="fa fa-list-check"></i>Task Tracking</a></li>
                        <li><a href="#"><i class="fa fa-users"></i>Team Management</a></li>
                        <li><a href="#"><i class="fa fa-gauge"></i>Admin Dashboard</a></li>
                        <li><a href="#"><i class="fa fa-chart-bar"></i>Progress Reports</a></li>
                    </ul>
                </div>

                <!-- Contact / info -->
                <div class="col-lg-4 col-md-6">
                    <p class="footer-heading">About</p>
                    <ul class="footer-links">
                        <li>
                            <a href="#"><i class="fa fa-envelope"></i>support@taskmanager.app</a>
                        </li>
                        <li>
                            <a href="#"><i class="fa fa-circle-info"></i>Version 1.0.0</a>
                        </li>
                        <li>
                            <a href="#"><i class="fa fa-file-contract"></i>Terms of Service</a>
                        </li>
                    </ul>
                </div>

            </div>

            <!-- Footer bottom bar -->
            <div class="footer-bottom">
                <p>&copy; 2026 TaskManager Web App — All rights reserved.</p>
                <div class="socials">
                    <a href="#" title="GitHub"><i class="fa-brands fa-github"></i></a>
                    <a href="#" title="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
                    <a href="#" title="Twitter"><i class="fa-brands fa-x-twitter"></i></a>
                </div>
            </div>

        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.js"></script>
    <script src="https://cdn.datatables.net/1.10.16/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
    <script src="https://kit.fontawesome.com/e19c476714.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
